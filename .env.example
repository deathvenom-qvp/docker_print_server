# =============================================================================
# Docker Print Server Configuration
# =============================================================================
#
# These environment variables can be set in this .env file, which Docker
# Compose will automatically read. They override the defaults set in
# docker-compose.yml.
#
# Alternatively, edit the 'environment' section in docker-compose.yml directly.
#
# IMPORTANT: Change all default passwords for production deployments!
#
# =============================================================================

# =============================================================================
# SECURITY SETTINGS - CHANGE THESE FOR PRODUCTION!
# =============================================================================

# Password for CUPS administration (root user)
# Used to access CUPS web interface at http://server:631/admin
# CUPS_ADMIN_PASSWORD=adminpassword

# Username for Samba printer sharing (Windows clients use this to connect)
# Windows access: \\server\printers with this username
# SAMBA_USER=printuser

# Password for Samba printer sharing
# Used when accessing printers via Windows at \\server\printers
# SAMBA_PASSWORD=printers

# =============================================================================
# SERVER SETTINGS
# =============================================================================

# Display name for the print server
# CUPS_SERVER_NAME=Print Server

# Timezone (see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
# Examples: America/New_York, Europe/London, Asia/Tokyo
# TZ=UTC
